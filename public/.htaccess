<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Si el archivo o carpeta existe, sírvelo directamente (css, js, imagenes)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Todo lo demás mándalo a index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>