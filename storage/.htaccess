# storage/.htaccess

# --- BLOQUEO TOTAL ---
# Esta carpeta ahora solo contiene Backups y Logs.
# Nada aquí debe ser accesible desde el navegador.

# 1. Deshabilitar motor PHP (Defensa en profundidad)
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

# 2. Deshabilitar listados y ejecución CGI
Options -Indexes -ExecCGI

# 3. DENEGAR TODO EL ACCESO HTTP
Require all denied