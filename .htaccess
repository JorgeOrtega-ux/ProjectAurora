<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # IMPORTANTE: Redirigir la petición raíz a la carpeta public/
    RewriteRule ^$ public/ [L]

    # Redirigir todas las demás peticiones a public/
    # PERO excluimos la carpeta 'api' para que el fetch JS funcione
    RewriteCond %{REQUEST_URI} !^/ProjectAurora/public/
    RewriteCond %{REQUEST_URI} !^/ProjectAurora/api/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>