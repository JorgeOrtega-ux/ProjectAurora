<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Redirigir la petición raíz a la carpeta public/
    RewriteRule ^$ public/ [L]

    # Redirigir todas las demás peticiones a public/
    # (Evita bucles verificando si ya estamos en public)
    RewriteCond %{REQUEST_URI} !^/ProjectAurora/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>