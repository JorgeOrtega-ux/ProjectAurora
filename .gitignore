# --- SEGURIDAD (CRÍTICO) ---
# Ignorar el archivo de variables de entorno para no exponer contraseñas
.env

# --- DEPENDENCIAS (COMPOSER) ---
/vendor/

# --- LOGS Y REGISTROS ---
logs/app/*.log
logs/database/*.log
logs/security/*.log

# --- ALMACENAMIENTO DE USUARIO (PÚBLICO) ---
# [CAMBIO] Ignorar contenido de public/storage/profilePicture/custom/
public/storage/profilePicture/custom/*
!public/storage/profilePicture/custom/.gitkeep

# --- RESPALDOS DE BASE DE DATOS (RAÍZ) ---
# Ignoramos todo el contenido de backups excepto el .htaccess de seguridad
storage/backups/*
!storage/backups/.htaccess
!storage/backups/.gitkeep

# --- ARCHIVOS TEMPORALES (Descargas Zips) ---
storage/temp/*
!storage/temp/.gitkeep

# --- SISTEMA OPERATIVO E IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp